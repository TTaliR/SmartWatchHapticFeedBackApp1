<resources>
    <!-- Base application theme - Optimized for watches -->
    <style name="Theme.SmartWatchHapticSystem" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color - pure black for AMOLED -->
        <item name="android:statusBarColor">@color/background_dark</item>
        <!-- Navigation bar color - pure black for AMOLED -->
        <item name="android:navigationBarColor">@color/background_dark</item>
        <!-- Window background - pure black for AMOLED -->
        <item name="android:windowBackground">@color/background_dark</item>
    </style>
</resources>